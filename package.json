{
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epreston/enginelayer.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "browserslist": [
    "baseline 2025"
  ],
  "prettier": "@epreston/prettier-config",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^22.22.0 || >=24.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "lint": "eslint .",
    "format": "prettier --check \"**/*.js\"",
    "format:fix": "prettier --write \"**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@epreston/eslint-config": "^2.4.2",
    "@epreston/prettier-config": "^2.1.1",
    "@epreston/tsconfig": "^1.2.2",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
